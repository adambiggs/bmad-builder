{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BMad Manifest Schema",
  "description": "Schema for BMad skill/workflow/agent manifest.yaml files",

  "type": "object",

  "properties": {
    "bmad-type": {
      "description": "Type of BMad entity",
      "type": "string",
      "enum": ["bmad-workflow", "bmad-skill", "bmad-agent", "skill"],
      "bmad-required": ["bmad-workflow", "bmad-agent"]
    },

    "bmad-module-name": {
      "description": "Human-readable module name that corresponds to the module code this workflow will be a part of",
      "type": "string"
    },

    "bmad-module-code": {
      "description": "Short code for the module this will belong to - also affects the namespacing applied to the name",
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },

    "replaces": {
      "description": "Optional: Replace an existing BMad skill in a module. For example if you want to replace the existing create UX skill with your own custom version",
      "type": "string",
      "minLength": 1
    },

    "bmad-phase": {
      "description": "Which phase this belongs to (modules can define any custom phases)",
      "type": "string"
    },

    "bmad-required": {
      "description": "If true, this is a blocker for later things in the sequence. When this is the first required item, the helper will present it as required but also offer any optional items before it",
      "type": "boolean"
    },

    "bmad-requires": {
      "description": "Hard dependencies within a phase sequence - items listed here must complete before dependent items can run",
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "bmad-prefer-after": {
      "description": "Soft predecessors - nicer if these ran first",
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "bmad-prefer-before": {
      "description": "Soft successors - ideally run before these",
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "bmad-creates": {
      "description": "What artifact this produces",
      "type": "string"
    },

    "bmad-output-location-variable": {
      "description": "Config variable for output location",
      "type": "string"
    },

    "bmad-capabilities": {
      "description": "Internal prompts/capabilities for agents",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "description": "Internal prompt name (kebab-case)",
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "display-name": {
            "description": "Human-readable name for UI",
            "type": "string"
          },
          "description": {
            "description": "What this capability does and when to suggest it",
            "type": "string"
          },
          "phase": {
            "description": "When this capability applies",
            "type": "string",
            "enum": ["init", "always", "on-demand", "planning", "analysis", "design", "development", "testing", "deployment", "anytime"]
          },
          "required": {
            "description": "Is this capability required?",
            "type": "boolean"
          },
          "output": {
            "description": "What this capability produces",
            "type": "string"
          },
          "output-location-variable": {
            "description": "Config variable for output location",
            "type": "string"
          },
          "options": {
            "description": "Additional options or flags",
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["name", "display-name", "description"],
        "additionalProperties": false
      }
    },

    "bmad-agent": {
      "description": "Agent-specific configuration",
      "type": "object",
      "properties": {
        "persona": {
          "description": "Agent persona description",
          "type": "string"
        },
        "memory-enabled": {
          "description": "Does this agent have memory/continuity?",
          "type": "boolean"
        },
        "memory-location-variable": {
          "description": "Config variable for memory storage location",
          "type": "string"
        },
        "init-prompt": {
          "description": "Path to init prompt relative to skill folder",
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },

  "required": [],
  "additionalProperties": false
}
